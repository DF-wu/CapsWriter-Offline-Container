# Public image
CAPSWRITER_SERVER_IMAGE=ghcr.io/df-wu/capswriter-offline-server:latest

# Model selection
# qwen_asr      = default, better general path for this fork
# fun_asr_nano  = faster on the current Pascal/P4 benchmark path
CAPSWRITER_MODEL_TYPE=qwen_asr

# Qwen preset
# default      = primary preset; best overall default on current real-audio benchmark
# low_vram_gpu = ONNX on GPU, llama on CPU; useful when GPU helps but VRAM is limited
CAPSWRITER_QWEN_PRESET=default

# Inference hardware policy
# auto = prefer GPU, fall back to CPU
# gpu  = try GPU first, still fall back to CPU on probe/runtime failure
# cpu  = force CPU only
CAPSWRITER_INFERENCE_HARDWARE=auto

# Compose-level GPU request
# all = expose visible GPUs to the container
# 0   = CPU-only startup
CAPSWRITER_GPU_DEVICE_COUNT=all

# Networking and logs
CAPSWRITER_SERVER_PORT=6016
CAPSWRITER_LOG_LEVEL=INFO

# ==================== OpenAI-Compatible HTTP API (opt-in) ====================
# Expose POST /v1/audio/transcriptions in addition to WebSocket. The OpenAI
# Python/Node SDKs can use this endpoint by setting base_url. See docs/HTTP_API.md.
CAPSWRITER_HTTP_API_ENABLE=false
CAPSWRITER_HTTP_API_BIND=127.0.0.1
CAPSWRITER_HTTP_API_PORT=6017
# Bearer token. Empty disables auth (only safe behind a private bind address).
CAPSWRITER_HTTP_API_KEY=
CAPSWRITER_HTTP_API_MAX_UPLOAD_MB=100
CAPSWRITER_HTTP_API_TASK_TIMEOUT=600

# Shared CPU thread hint for CPU-bound stages
CAPSWRITER_NUM_THREADS=4

# Remove downloaded archives after extraction if disk is tight
CAPSWRITER_REMOVE_MODEL_ARCHIVES=false

# ==================== Qwen tuning ====================
CAPSWRITER_QWEN_CHUNK_SIZE=10
CAPSWRITER_QWEN_N_CTX=1024
CAPSWRITER_QWEN_MEMORY_NUM=1
CAPSWRITER_QWEN_PAD_TO=10
CAPSWRITER_QWEN_N_PREDICT=256
CAPSWRITER_QWEN_VULKAN_ENABLE=true
CAPSWRITER_QWEN_USE_CUDA=true
CAPSWRITER_QWEN_LLAMA_N_BATCH=
CAPSWRITER_QWEN_LLAMA_N_UBATCH=
CAPSWRITER_QWEN_LLAMA_FLASH_ATTN=
CAPSWRITER_QWEN_LLAMA_OFFLOAD_KQV=

# ==================== Fun-ASR tuning ====================
CAPSWRITER_FUNASR_ENABLE_CTC=true
CAPSWRITER_FUNASR_N_PREDICT=512
CAPSWRITER_FUNASR_PAD_TO=30
CAPSWRITER_FUNASR_MAX_HOTWORDS=20
CAPSWRITER_FUNASR_SIMILAR_THRESHOLD=0.6
CAPSWRITER_FUNASR_VULKAN_ENABLE=true
CAPSWRITER_FUNASR_USE_CUDA=true

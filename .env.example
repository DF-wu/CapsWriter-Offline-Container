# CAPSWRITER_SERVER_IMAGE
# Purpose: Docker image tag used for the server container.
# Allowed: any valid image reference
# Default: ghcr.io/df-wu/capswriter-offline-server:latest
CAPSWRITER_SERVER_IMAGE=ghcr.io/df-wu/capswriter-offline-server:latest

# CAPSWRITER_MODEL_TYPE
# Purpose: Select the server recognition stack.
# Allowed: qwen_asr | fun_asr_nano
# Default: qwen_asr
CAPSWRITER_MODEL_TYPE=qwen_asr

# CAPSWRITER_QWEN_PRESET
# Purpose: Select the official Qwen runtime profile.
# Allowed: default | cpu_only
# Compatibility aliases accepted internally: low_vram_gpu, balanced, quality, defaults, cpu
# Default: default
# Resolution order:
#   1) normalize preset / alias
#   2) load preset defaults
#   3) apply explicit Qwen env overrides
#   4) apply CAPSWRITER_INFERENCE_HARDWARE constraint
#   5) apply runtime fallback if requested hardware is unavailable
# Official profiles:
#   default  = recommended path for this fork: ONNX GPU + llama CPU
#   cpu_only = pure CPU path
CAPSWRITER_QWEN_PRESET=default

# CAPSWRITER_INFERENCE_HARDWARE
# Purpose: Constrain the resolved runtime profile.
# Allowed: auto | gpu | cpu
# Default: auto
# Meaning:
#   auto = allow GPU when available, otherwise fall back safely
#   gpu  = request GPU-first startup, still fall back safely if runtime support is absent
#   cpu  = force CPU-only runtime regardless of preset or advanced backend overrides
CAPSWRITER_INFERENCE_HARDWARE=auto

# CAPSWRITER_GPU_DEVICE_COUNT
# Purpose: Docker Compose GPU device request.
# Allowed: all | 0
# Default: all
# Note: set to 0 when you want a CPU-only container startup.
CAPSWRITER_GPU_DEVICE_COUNT=all

# CAPSWRITER_SERVER_PORT
# Purpose: WebSocket listen port exposed by the server.
# Default: 6016
CAPSWRITER_SERVER_PORT=6016

# CAPSWRITER_LOG_LEVEL
# Purpose: Server log verbosity.
# Allowed: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
CAPSWRITER_LOG_LEVEL=INFO

# CAPSWRITER_NUM_THREADS
# Purpose: Shared CPU thread hint for CPU-bound stages.
# Default: 4 in the deployment templates; the runtime also accepts empty / auto behavior.
CAPSWRITER_NUM_THREADS=4

# CAPSWRITER_REMOVE_MODEL_ARCHIVES
# Purpose: Remove downloaded model archives after extraction.
# Allowed: true | false
# Default: false
CAPSWRITER_REMOVE_MODEL_ARCHIVES=false

# ==================== Qwen preset-derived defaults ====================
# These values are loaded by preset before explicit overrides apply.
# Explicit non-empty env values below override preset defaults.
#
# Preset: default
#   use_cuda=true
#   use_dml=false
#   vulkan_enable=false
#   llama_backend=cpu
#   n_ctx=2048
#   chunk_size=40
#   memory_num=1
#   pad_to=30
#   n_predict=512
#   llama_n_batch=4096
#   llama_n_ubatch=512
#   llama_flash_attn=true
#   llama_offload_kqv=true
#
# Preset: cpu_only
#   use_cuda=false
#   use_dml=false
#   vulkan_enable=false
#   llama_backend=cpu
#   n_ctx=2048
#   chunk_size=40
#   memory_num=1
#   pad_to=30
#   n_predict=512
#   llama_n_batch=4096
#   llama_n_ubatch=512
#   llama_flash_attn=true
#   llama_offload_kqv=true

# CAPSWRITER_QWEN_CHUNK_SIZE
# Purpose: Audio seconds per Qwen chunk.
# Type: float
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_CHUNK_SIZE=

# CAPSWRITER_QWEN_N_CTX
# Purpose: llama.cpp context window used by Qwen decoding.
# Type: int
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_N_CTX=

# CAPSWRITER_QWEN_MEMORY_NUM
# Purpose: Number of previous Qwen memory segments used during prompt construction.
# Type: int
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_MEMORY_NUM=

# CAPSWRITER_QWEN_PAD_TO
# Purpose: Warmup / fixed-shape padding length in seconds for GPU/DML ONNX sessions.
# Type: int
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_PAD_TO=

# CAPSWRITER_QWEN_N_PREDICT
# Purpose: Maximum generated tokens per chunk.
# Type: int
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_N_PREDICT=

# CAPSWRITER_QWEN_LLAMA_N_BATCH
# Purpose: llama.cpp logical batch size.
# Type: int
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_LLAMA_N_BATCH=

# CAPSWRITER_QWEN_LLAMA_N_UBATCH
# Purpose: llama.cpp physical micro-batch size.
# Type: int
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_LLAMA_N_UBATCH=

# CAPSWRITER_QWEN_LLAMA_FLASH_ATTN
# Purpose: Toggle llama.cpp flash attention.
# Allowed: true | false
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_LLAMA_FLASH_ATTN=

# CAPSWRITER_QWEN_LLAMA_OFFLOAD_KQV
# Purpose: Toggle llama.cpp KQV offload path.
# Allowed: true | false
# Override behavior: explicit non-empty value overrides the preset default.
CAPSWRITER_QWEN_LLAMA_OFFLOAD_KQV=

# ==================== Advanced / internal Qwen backend overrides ====================
# These settings are intentionally advanced.
# In normal use, leave them empty and let the preset resolve the backend profile.
# If you set them explicitly, they override preset defaults first, but can still be
# constrained by CAPSWRITER_INFERENCE_HARDWARE=cpu or by runtime fallback.

# CAPSWRITER_QWEN_USE_CUDA
# Purpose: Explicitly request or disable CUDA for the Qwen ONNX encoder.
# Allowed: true | false
CAPSWRITER_QWEN_USE_CUDA=

# CAPSWRITER_QWEN_VULKAN_ENABLE
# Purpose: Explicitly request or disable Vulkan for the Qwen llama / GGUF path.
# Allowed: true | false
CAPSWRITER_QWEN_VULKAN_ENABLE=

# CAPSWRITER_QWEN_VULKAN_FORCE_FP32
# Purpose: Force FP32 in Vulkan backend when debugging precision issues.
# Allowed: true | false
CAPSWRITER_QWEN_VULKAN_FORCE_FP32=

# ==================== Fun-ASR tuning ====================
CAPSWRITER_FUNASR_ENABLE_CTC=true
CAPSWRITER_FUNASR_N_PREDICT=512
CAPSWRITER_FUNASR_PAD_TO=30
CAPSWRITER_FUNASR_MAX_HOTWORDS=20
CAPSWRITER_FUNASR_SIMILAR_THRESHOLD=0.6
CAPSWRITER_FUNASR_VULKAN_ENABLE=true
CAPSWRITER_FUNASR_USE_CUDA=true

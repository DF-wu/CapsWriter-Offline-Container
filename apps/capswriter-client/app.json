{
  "expo": {
    "name": "CapsWriter Client",
    "slug": "capswriter-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "capswriter-client",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.capswriter.client",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "CapsWriter Client records microphone audio for transcription."
      }
    },
    "android": {
      "package": "app.capswriter.client",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-secure-store",
      "expo-asset"
    ]
  }
}

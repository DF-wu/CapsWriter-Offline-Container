# Public image
CAPSWRITER_SERVER_IMAGE=ghcr.io/df-wu/capswriter-offline-server:latest

# Model selection
# qwen_asr      = default deployment target for this fork
# fun_asr_nano  = alternate supported path
CAPSWRITER_MODEL_TYPE=qwen_asr

# Qwen preset
# default  = official recommended path for this fork: ONNX on GPU + llama on CPU
# cpu_only = official pure CPU path
# Legacy aliases are still accepted internally: low_vram_gpu, balanced, quality, defaults, cpu
CAPSWRITER_QWEN_PRESET=default

# Inference hardware policy
# auto = allow GPU when available and fall back safely otherwise
# gpu  = request GPU-first startup, still fall back safely if unavailable
# cpu  = force CPU-only runtime regardless of preset
CAPSWRITER_INFERENCE_HARDWARE=auto

# Compose-level GPU request
# all = expose visible GPUs to the container
# 0   = CPU-only startup
CAPSWRITER_GPU_DEVICE_COUNT=all

# Networking and logs
CAPSWRITER_SERVER_PORT=6016
CAPSWRITER_LOG_LEVEL=INFO

# Shared CPU thread hint for CPU-bound stages
CAPSWRITER_NUM_THREADS=4

# Keep downloaded archives unless you are short on disk.
CAPSWRITER_REMOVE_MODEL_ARCHIVES=false

# ==================== Qwen tuning ====================
# Explicit non-empty values override preset defaults.
# Leave blank to follow the selected preset.
CAPSWRITER_QWEN_CHUNK_SIZE=
CAPSWRITER_QWEN_N_CTX=
CAPSWRITER_QWEN_MEMORY_NUM=
CAPSWRITER_QWEN_PAD_TO=
CAPSWRITER_QWEN_N_PREDICT=
CAPSWRITER_QWEN_LLAMA_N_BATCH=
CAPSWRITER_QWEN_LLAMA_N_UBATCH=
CAPSWRITER_QWEN_LLAMA_FLASH_ATTN=
CAPSWRITER_QWEN_LLAMA_OFFLOAD_KQV=

# ==================== Advanced / internal Qwen backend overrides ====================
# Leave blank unless you are deliberately overriding the preset-derived backend profile.
CAPSWRITER_QWEN_USE_CUDA=
CAPSWRITER_QWEN_VULKAN_ENABLE=
CAPSWRITER_QWEN_VULKAN_FORCE_FP32=

# ==================== Fun-ASR tuning ====================
CAPSWRITER_FUNASR_ENABLE_CTC=true
CAPSWRITER_FUNASR_N_PREDICT=512
CAPSWRITER_FUNASR_PAD_TO=30
CAPSWRITER_FUNASR_MAX_HOTWORDS=20
CAPSWRITER_FUNASR_SIMILAR_THRESHOLD=0.6
CAPSWRITER_FUNASR_VULKAN_ENABLE=true
CAPSWRITER_FUNASR_USE_CUDA=true
